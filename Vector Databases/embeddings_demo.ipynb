from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity
import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np

sentences = [

    # Cricket (4)
    "The batsman scored a brilliant century in the final match.",
    "Fast bowlers rely on swing and pace to trouble the batter.",
    "The team celebrated after winning the cricket world cup.",
    "Fielders must stay alert to catch edges behind the wicket.",

    # Cooking (3)
    "Adding fresh spices enhances the flavor of the curry.",
    "The chef baked a chocolate cake in the oven.",
    "Boiling vegetables for too long reduces their nutrients.",

    # Cybersecurity (3)
    "Strong passwords help protect systems from cyber attacks.",
    "Firewalls monitor incoming and outgoing network traffic.",
    "Phishing emails attempt to steal sensitive user information."
]

model = SentenceTransformer('all-MiniLM-L6-v2')

embeddings = model.encode(sentences)

similarity_matrix = cosine_similarity(embeddings)

plt.figure(figsize=(10,8))
sns.heatmap(similarity_matrix, annot=False, cmap="coolwarm")
plt.title("Cosine Similarity Heatmap")
plt.show()

query = "The bowler took three wickets in one over"

query_embedding = model.encode([query])

scores = cosine_similarity(query_embedding, embeddings)[0]

top_indices = np.argsort(scores)[-2:][::-1]

print("Query:", query)
print("\nTop 2 similar sentences:\n")

for idx in top_indices:
    print(sentences[idx])
    print("Similarity Score:", scores[idx])
    print()



